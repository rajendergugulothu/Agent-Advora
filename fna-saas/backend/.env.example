# Environment
ENVIRONMENT=development
DEBUG=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex characters (32 bytes). Used for Fernet encryption of stored tokens.
ENCRYPTION_KEY=your_64_char_hex_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=advora_posts

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# Meta / Instagram OAuth
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_OAUTH_REDIRECT_URI=https://yourdomain.com/api/v1/instagram/callback

# Sentry (optional)
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Scheduler
# Set false on Vercel/serverless. Use a long-lived host or cron job for scheduled posting.
ENABLE_SCHEDULER=true

# Frontend URL (used for OAuth callback redirect after Instagram connect)
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]
